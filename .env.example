ADMIN_NOTIFY_PHONE=+905XXXXXXXXX

# SMS Sağlayıcı: twilio | netgsm  (boş bırakırsanız sadece console log yapılır)
SMS_PROVIDER=

# Twilio (SMS_PROVIDER=twilio ise)
# Yöntem 1 — API Key (önerilen):
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxx
TWILIO_FROM=+1XXXXXXXXXX
# Yöntem 2 — Auth Token (klasik):
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxx
# TWILIO_TOKEN=xxxxxxxxxxxxxxxx
# TWILIO_FROM=+1XXXXXXXXXX

# NetGSM (SMS_PROVIDER=netgsm ise — Türkiye)
NETGSM_USER=XXXXXXXXXX
NETGSM_PASS=XXXXXXXXXX
NETGSM_HEADER=GULIZ
